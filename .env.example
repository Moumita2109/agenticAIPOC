# Copy to `.env` and fill in locally. `.env` is gitignored — never commit secrets.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Target app (no default in tests — they skip if unset)
BASE_URL=https://the-internet.herokuapp.com

# Valid-login test
LOGIN_USERNAME=tomsmith
LOGIN_PASSWORD=SuperSecretPassword!

# Invalid-login test
INVALID_LOGIN_USERNAME=not_a_user
INVALID_LOGIN_PASSWORD=bad_password
# Optional hint for the agent (substring expected in the error UI)
INVALID_LOGIN_EXPECTED_TEXT=Your username is invalid!

# Optional: path to mcp.json (defaults: .cursor/mcp.json, then ~/.cursor/mcp.json)
# PLAYWRIGHT_MCP_CONFIG=
# MCP server key inside mcp.json (default: playwright)
# PLAYWRIGHT_MCP_SERVER_NAME=playwright

# Plan-driven tests (default: ./plan.md)
# PLAN_MD_PATH=plan.md
# Optional model for extracting scenarios from plan.md when no plan-scenarios fence exists
# PLAN_EXTRACT_MODEL=gpt-4o-mini
