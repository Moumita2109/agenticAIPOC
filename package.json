{
  "name": "agentic-playwright-mcp-poc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "POC: agentic test automation with Playwright and LLM tool calls",
  "scripts": {
    "agent:test": "playwright test src/tests/agentic.spec.ts",
    "agent:test:headed": "playwright test src/tests/agentic.spec.ts --headed",
    "allure:generate": "allure generate allure-results -o allure-report --clean",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "postinstall": "playwright install chromium",
    "playwright:install": "playwright install chromium"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.7",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.70",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.13.10",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.1",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20"
  }
}
